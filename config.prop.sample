##########################################################
# All variables in config.prop are optional
# Removing or leaving them blank will keep default values
##########################################################

# The version name of Magisk. Default: git HEAD short SHA1
# version=X.Y.Z

# Output path. Default: out
# outdir=out

# List of ABIs to build, separated with ','
# Default: armeabi-v7a,x86,arm64-v8a,x86_64
# 
# 🎯 RECOMMENDED FOR MODERN DEVICES (ARM64 only):
# Copy this file to 'config.prop' and uncomment the line below
# abiList=arm64-v8a
#
# This will build ONLY for ARM64 (faster builds, optimized for devices like RMX3834)
# For all architectures, use: abiList=armeabi-v7a,x86,arm64-v8a,x86_64

#####################################################
# Device-specific examples:
#####################################################
# RMX3834 (Realme GT Neo 3T, ARM64):
# abiList=arm64-v8a
#
# All architectures (slower build):
# abiList=armeabi-v7a,x86,arm64-v8a,x86_64

#####################################################
# Signing configs for signing zips and APKs
# These 4 variables has to be either all set or not
#####################################################

# Path to keystore file
# keyStore=/path/to/keystore.jks
# Keystore password
# keyStorePass=your_store_password
# The desired key alias in the keystore
# keyAlias=your_key_alias
# Password of specified key alias
# keyPass=your_key_password
