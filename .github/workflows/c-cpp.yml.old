# DISABLED WORKFLOW - Renamed to .old
# 
# Reason: This is a template workflow that expects ./configure script. Native builds are handled by ci.yml using CMake.
#
# This workflow was disabled during repository cleanup to keep only
# relevant workflows for the Magisk_Rafaelia project.
#
# Original workflow content below:
# ========================================================================

name: C/C++ CI

on:
  push:
    branches: [ "master" ]
  pull_request:
    branches: [ "master" ]

jobs:
  build:

    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v4
    - name: configure
      run: ./configure
    - name: make
      run: make
    - name: make check
      run: make check
    - name: make distcheck
      run: make distcheck
